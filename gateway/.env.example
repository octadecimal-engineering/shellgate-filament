# Shell Gate Gateway Configuration

# Server
PORT=7681
HOST=127.0.0.1

# JWT secret (must match Laravel config - use APP_KEY or SHELL_GATE_JWT_SECRET)
JWT_SECRET=your-secret-key-here

# Allowed origins (comma-separated, empty = allow all for local dev)
# Set to your production domain(s) in production, e.g.: https://admin.example.com
ALLOWED_ORIGINS=

# Session limits
MAX_SESSIONS=100
SESSION_TIMEOUT=0
IDLE_TIMEOUT=1800

# Shell
SHELL=/bin/bash
# Working directory for terminal (empty = user home directory, install.sh sets this to Laravel root)
DEFAULT_CWD=

# Logging (debug, info, warn, error)
LOG_LEVEL=info
