{
    "name": "octadecimalhq/shellgate",
    "description": "Real bash terminal in Filament admin panel — PTY + WebSocket. JWT, audit, wss://.",
    "keywords": [
        "filament",
        "filament-3",
        "filament-4",
        "filament-5",
        "terminal",
        "web-terminal",
        "pty",
        "websocket",
        "octadecimal"
    ],
    "homepage": "https://github.com/octadecimalhq/shellgate",
    "license": "proprietary",
    "authors": [
        {
            "name": "Octadecimal Engineering",
            "email": "dev@octadecimal.engineering"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0|^4.0|^5.0",
        "firebase/php-jwt": "^6.10|^7.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload-dev": {
        "psr-4": {
            "OctadecimalHQ\\ShellGate\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "lint": "pint",
        "analyse": "phpstan analyse src --level=8"
    },
    "autoload": {
        "psr-4": {
            "OctadecimalHQ\\ShellGate\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OctadecimalHQ\\ShellGate\\ShellGateServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
